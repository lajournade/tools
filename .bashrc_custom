#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# ---------------------------------------
# IMPROVE DEFAULTS COMMANDS
# ---------------------------------------
alias ls='ls --color=auto'
alias ll="ls -la"
alias grep='grep --color=auto'

# ---------------------------------------
# CUSTOM TERMINAL 
# ---------------------------------------
fastfetch --load-config examples/18
eval "$(oh-my-posh init bash --config ~/.config/ohmyposh/catppuccin_latte.omp.json)"

